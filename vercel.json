{
    "version": 2,
    "builds": [
        {
            "src": "backend/server.js",
            "use": "@vercel/node"
        },
        {
            "src": "frontend/index.html",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/script.js",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/style.css",
            "use": "@vercel/static"
        },
        {
            "src": "frontend/pdp.css",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/server.js"
        },
        {
            "src": "/script.js",
            "dest": "/frontend/script.js"
        },
        {
            "src": "/style.css",
            "dest": "/frontend/style.css"
        },
        {
            "src": "/pdp.css",
            "dest": "/frontend/pdp.css"
        },
        {
            "src": "/(.*)",
            "dest": "/frontend/index.html"
        }
    ]
}